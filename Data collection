# STEP 1: Data Collection

# Read the wine dataset from the UCI repository
wine <- read.csv(url("https://archive.ics.uci.edu/ml/machine-learning-databases/wine/wine.data"), header = FALSE)
head(wine)
dim(wine)

#column name 
colnames(wine) <- c("Class","Alcohol","Malic_Acid","Ash","Alcalinity_Ash", "Magnesium","Total_Phenols","Flavanoids","Nonflavanoid_Phenols",
                    "Proanthocyanins","Color_Intensity","Hue", "OD280_OD315","Proline")

# structure
str(wine)

# summary statistics
summary(wine)

# check missing values
sum(is.na(wine))

# class distribution
table(wine$Class)
