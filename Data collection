# STEP 1: Data Collection

# Read the wine dataset from the UCI repository
wine <- read.csv(url("https://archive.ics.uci.edu/ml/machine-learning-databases/wine/wine.data"), header = FALSE)

# View the structure of the dataset
str(wine)

# Check dimensions (rows and columns)
dim(wine)

# Look at the first few rows
head(wine)

# STEP 2: Data Exploration and Preparation

# Assign column names based on dataset description
colnames(wine) <- c("Class","Alcohol","Malic_Acid","Ash","Alcalinity_Ash",
                    "Magnesium","Total_Phenols","Flavanoids","Nonflavanoid_Phenols",
                    "Proanthocyanins","Color_Intensity","Hue",
                    "OD280_OD315","Proline")

# Check structure again
str(wine)

# Summary statistics
summary(wine)

# Check for missing values
sum(is.na(wine))

# View class distribution
table(wine$Class)
