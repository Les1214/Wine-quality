# STEP 1: Data Collection

# Read the wine dataset from the UCI repository
wine <- read.csv(url("https://archive.ics.uci.edu/ml/machine-learning-databases/wine/wine.data"), header = FALSE)

# view first few rows
head(wine)

#view data set size
dim(wine)

#column name 
colnames(wine) <- c("Class","Alcohol","Malicacid","Ash","Alcalinity_of_Ash", "Magnesium","Total_Phenols","Flavanoids","Nonflavanoid_Phenols",
                    "Proanthocyanins","Color_Intensity","Hue", "OD280_OD315_of_diluted_wines","Proline")

# structure
str(wine)

# summary statistics
summary(wine)

# check missing values
sum(is.na(wine))

# class distribution
table(wine$Class)
